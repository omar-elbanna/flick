# =============================================================================
# Flick backend environment configuration
# Copy to .env and fill every value. The app refuses to start if any are missing.
# =============================================================================

# Runtime environment: "development" | "production" | "test"
ENVIRONMENT=development

# PostgreSQL — use the async asyncpg driver
DATABASE_URL=postgresql+asyncpg://flick:flick@postgres:5432/flick

# Redis connection URL
REDIS_URL=redis://redis:6379/0

# RSA key pair for JWT RS256 signing.
# Generate via:  python scripts/generate_rsa_keys.py
# Paste full PEM strings as single line with \n escapes, or use multi-line vars.
RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----\n"

# Google OAuth 2.0 credentials (console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# External APIs (server-side only — never expose to the frontend)
TMDB_API_KEY=your-tmdb-api-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Public frontend URL (used for OAuth final redirect and cookie domain hints)
FRONTEND_URL=http://localhost:3000

# CORS — strict whitelist, comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Token TTLs (minutes for access, days for refresh)
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Session secret for OAuth state cookie signing (random 32+ bytes)
SESSION_SECRET=change-me-to-a-long-random-string
